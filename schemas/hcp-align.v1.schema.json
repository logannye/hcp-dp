{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/logannye/hcp-dp/blob/main/schemas/hcp-align.v1.schema.json",
  "title": "hcp-align report",
  "description": "Per-pair structured output record emitted by hcp-align.",
  "type": "object",
  "required": [
    "schema_version",
    "engine",
    "pair_index",
    "query_id",
    "target_id",
    "mode",
    "score",
    "distance",
    "path_score",
    "verification_status",
    "verified",
    "query_start",
    "query_end",
    "target_start",
    "target_end",
    "cigar",
    "block_size",
    "path_length",
    "summary_build_ms",
    "reconstruction_ms",
    "verification_ms",
    "elapsed_ms"
  ],
  "properties": {
    "schema_version": { "const": "hcp-align.v1" },
    "engine": { "const": "hcp-dp" },
    "pair_index": { "type": "integer", "minimum": 0 },
    "query_id": { "type": "string" },
    "target_id": { "type": "string" },
    "mode": {
      "enum": [
        "global-linear",
        "global-affine",
        "local-linear",
        "edit-distance",
        "semiglobal-linear",
        "seeded-global-linear"
      ]
    },
    "score": { "type": ["integer", "null"] },
    "distance": { "type": ["integer", "null"], "minimum": 0 },
    "path_score": { "type": ["integer", "null"] },
    "verification_status": { "enum": ["full", "path_only", "score_only", "failed"] },
    "verified": { "type": ["boolean", "null"] },
    "query_start": { "type": "integer", "minimum": 0 },
    "query_end": { "type": "integer", "minimum": 0 },
    "target_start": { "type": "integer", "minimum": 0 },
    "target_end": { "type": "integer", "minimum": 0 },
    "cigar": { "type": "string" },
    "backend": {
      "description": "Optional problem-specific backend label. Omitted for the default HCP engine.",
      "enum": [
        "hcp-linear",
        "adaptive-banded",
        "myers",
        "wavefront-affine",
        "minimizer-seeded"
      ]
    },
    "operation_counts": {
      "type": "array",
      "items": { "$ref": "#/$defs/operation_count" }
    },
    "operations": {
      "type": "array",
      "items": { "$ref": "#/$defs/operation" }
    },
    "certificate": {
      "$ref": "#/$defs/certificate"
    },
    "block_size": {
      "description": "HCP summary-tree block size. Non-HCP exact backends use 0.",
      "type": "integer",
      "minimum": 0
    },
    "path_length": { "type": "integer", "minimum": 0 },
    "summary_build_ms": { "type": "number", "minimum": 0 },
    "reconstruction_ms": { "type": "number", "minimum": 0 },
    "verification_ms": { "type": "number", "minimum": 0 },
    "aligned_query": { "type": "string" },
    "aligned_target": { "type": "string" },
    "error": { "type": "string" },
    "elapsed_ms": { "type": "number", "minimum": 0 }
  },
  "additionalProperties": false,
  "$defs": {
    "operation_kind": {
      "enum": ["match", "mismatch", "gap_in_target", "gap_in_query"]
    },
    "operation_count": {
      "type": "object",
      "required": ["op", "count"],
      "properties": {
        "op": { "$ref": "#/$defs/operation_kind" },
        "count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "operation": {
      "type": "object",
      "required": [
        "op",
        "query_pos",
        "target_pos",
        "query_base",
        "target_base"
      ],
      "properties": {
        "op": { "$ref": "#/$defs/operation_kind" },
        "query_pos": { "type": ["integer", "null"], "minimum": 0 },
        "target_pos": { "type": ["integer", "null"], "minimum": 0 },
        "query_base": { "type": ["string", "null"], "maxLength": 1 },
        "target_base": { "type": ["string", "null"], "maxLength": 1 }
      },
      "additionalProperties": false
    },
    "certificate": {
      "type": "object",
      "required": [
        "version",
        "hash_algorithm",
        "query_sha256",
        "target_sha256",
        "parameters_sha256",
        "trace_sha256",
        "result_sha256",
        "certificate_sha256"
      ],
      "properties": {
        "version": { "const": "hcp-align.certificate.v1" },
        "hash_algorithm": { "const": "sha256" },
        "query_sha256": { "$ref": "#/$defs/sha256" },
        "target_sha256": { "$ref": "#/$defs/sha256" },
        "parameters_sha256": { "$ref": "#/$defs/sha256" },
        "trace_sha256": { "anyOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }] },
        "result_sha256": { "$ref": "#/$defs/sha256" },
        "certificate_sha256": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
